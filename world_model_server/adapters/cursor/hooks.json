{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/world-model-inject.js UserPromptSubmit",
        "timeout": 6,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": "node .cursor/hooks/world-model-validate.js",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/hooks/world-model-inject.js PostCompact",
        "timeout": 6,
        "failClosed": false
      }
    ]
  }
}
