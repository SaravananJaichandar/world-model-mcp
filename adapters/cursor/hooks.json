{
  "version": "1",
  "hooks": [
    {
      "event": "beforeSubmitPrompt",
      "command": "node ${workspaceFolder}/.claude/hooks/world-model-inject.js UserPromptSubmit",
      "timeout_ms": 6000,
      "fail_open": true
    },
    {
      "event": "beforeEdit",
      "matcher": "Edit|Write|MultiEdit",
      "command": "node ${workspaceFolder}/.claude/hooks/world-model-validate.js",
      "timeout_ms": 8000,
      "fail_open": true
    },
    {
      "event": "afterCompact",
      "command": "node ${workspaceFolder}/.claude/hooks/world-model-inject.js PostCompact",
      "timeout_ms": 6000,
      "fail_open": true
    }
  ]
}
