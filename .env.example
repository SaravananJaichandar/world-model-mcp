# World Model MCP Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env files to git!

# ============================================================
# Database Configuration
# ============================================================

# Path to SQLite databases (default: ./.claude/world-model/)
# WORLD_MODEL_DB_PATH="./.claude/world-model/"

# ============================================================
# Anthropic API Configuration
# ============================================================

# Anthropic API key (optional - enables LLM-powered extraction)
# Get your API key from: https://console.anthropic.com/
# Without this key, the system falls back to regex-based extraction
ANTHROPIC_API_KEY=your-api-key-here

# Model selection for different tasks
# WORLD_MODEL_EXTRACTION_MODEL=claude-3-haiku-20240307      # Fast, cost-effective
# WORLD_MODEL_REASONING_MODEL=claude-3-5-sonnet-20241022    # Accurate, complex tasks

# ============================================================
# Performance Tuning
# ============================================================

# Maximum facts returned per query (default: 10)
# WORLD_MODEL_MAX_FACTS_PER_QUERY=10

# Confidence threshold for blocking operations (default: 0.6)
# Higher = more conservative (blocks more), Lower = more permissive
# WORLD_MODEL_CONFIDENCE_THRESHOLD=0.6

# ============================================================
# Debugging
# ============================================================

# Enable debug logging (default: 0)
# Set to 1 to enable verbose logging
WORLD_MODEL_DEBUG=0

# ============================================================
# Advanced Configuration
# ============================================================

# Custom linter paths (optional)
# ESLINT_PATH="/custom/path/to/eslint"
# PYLINT_PATH="/custom/path/to/pylint"
# RUFF_PATH="/custom/path/to/ruff"

# Session timeout in minutes (default: 60)
# WORLD_MODEL_SESSION_TIMEOUT=60

# Fact retention period in days (default: 90)
# Older facts are automatically archived
# WORLD_MODEL_FACT_RETENTION_DAYS=90

# ============================================================
# Notes
# ============================================================

# 1. This file should be copied to .env in your project root
# 2. Never commit .env files - they contain sensitive credentials
# 3. The .gitignore file automatically excludes .env files
# 4. All settings are optional - defaults work for most use cases
# 5. Changes require restarting Claude Code to take effect
