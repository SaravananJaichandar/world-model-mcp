# world-model-mcp HTTP transport image
#
# Streamable-HTTP variant for remote deployment behind an MCP tunnel
# (e.g. Anthropic Claude Managed Agents MCP tunnels, ngrok, Cloudflare Tunnel).
# The stdio image (Dockerfile) remains the default for Claude Code / Cursor /
# .mcpb installs.

FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY world_model_server ./world_model_server

# Install the package WITH http extras (uvicorn + starlette)
RUN pip install --no-cache-dir ".[http]"

ENV WORLD_MODEL_DB_PATH=/data/world-model \
    WORLD_MODEL_TRANSPORT=http \
    WORLD_MODEL_HTTP_HOST=0.0.0.0 \
    WORLD_MODEL_HTTP_PORT=8765 \
    WORLD_MODEL_HTTP_PATH=/mcp

VOLUME ["/data"]
EXPOSE 8765

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8765/healthz || exit 1

ENTRYPOINT ["python3", "-m", "world_model_server.server"]
